  window._cards = {};       // id → card object
  window._mode  = "firebase"; // fallback to local if config missing

  const syncDot = document.getElementById("syncDot");

  if (firebaseConfig.apiKey === "REPLACE_API_KEY") {
    window._mode = "local";
    syncDot.classList.add("offline");
    syncDot.title = "Sin Firebase — usando localStorage";
    loadLocal();
  } else {
    syncDot.classList.add("syncing");
    onSnapshot(collection(db, COL), snap => {
      snap.docChanges().forEach(ch => {
        if (ch.type === "removed") {
          delete window._cards[ch.doc.id];
        } else {
          window._cards[ch.doc.id] = { id: ch.doc.id, ...ch.doc.data() };
        }
      });
      syncDot.className = "sync-dot";
      renderAll();
    }, () => {
      syncDot.classList.add("offline");
    });
  }

  // ── SAVE/DELETE ─────────────────────────────────────────────────────────
  window.persistCard = async (card) => {
    if (window._mode === "local") { saveLocal(); return; }
    syncDot.classList.add("syncing");
    const { id, ...data } = card;
    data.updatedAt = serverTimestamp();
    await setDoc(doc(db, COL, id), data);
  };

  window.removeCard = async (id) => {
    delete window._cards[id];
    if (window._mode === "local") { saveLocal(); renderAll(); return; }
    syncDot.classList.add("syncing");
    await deleteDoc(doc(db, COL, id));
  };

  function saveLocal() {
    localStorage.setItem("kanban_v2", JSON.stringify(window._cards));
    renderAll();
  }
  function loadLocal() {
    try { window._cards = JSON.parse(localStorage.getItem("kanban_v2") || "{}"); } catch(e){}
    renderAll();
  }
</script>

<script>
  // ── HELPERS ──────────────────────────────────────────────────────────────
  const uid = () => Date.now().toString(36) + Math.random().toString(36).slice(2,7);
  const fmt  = d => new Date(d).toLocaleDateString("es-PE",{day:"2-digit",month:"short"});
  const STATUS_LABEL = { todo:"Por hacer", prog:"En progreso", done:"Realizado", backlog:"Backlog" };
  const STATUS_PILL  = { todo:"pill-todo", prog:"pill-prog", done:"pill-done", backlog:"pill-backlog" };
  let dragId = null, activeImgCardId = null, editingId = null;

  // ── RENDER ───────────────────────────────────────────────────────────────
  function renderAll() {
    ["todo","prog","done"].forEach(s => {
      const wrap = document.getElementById("cards-"+s);
      const list = Object.values(window._cards).filter(c => c.status === s)
                    .sort((a,b)=>(a.order||0)-(b.order||0));
      wrap.innerHTML = "";
      list.forEach(c => wrap.appendChild(makeCard(c)));
      document.getElementById("cnt-"+s).textContent = list.length;
    });

    // backlog
    const blist = Object.values(window._cards).filter(c => c.status === "backlog")
                   .sort((a,b)=> b.createdAt - a.createdAt);
    const bl = document.getElementById("backlog-list");
    bl.innerHTML = "";
    blist.forEach(c => bl.appendChild(makeBacklogCard(c)));
    document.getElementById("cnt-backlog").textContent = blist.length;

    // auto-resize title textarea
    const t = document.getElementById("modalTitle");
    if (t) { t.style.height = "auto"; t.style.height = t.scrollHeight + "px"; }
  }

  function makeCard(card) {
    const div = document.createElement("div");
    div.className = "card";
    div.draggable = true;
    div.dataset.id = card.id;
    const imgCount = (card.images||[]).length;
    div.innerHTML = `
      <div class="card-title">${esc(card.title)}</div>
      <div class="card-meta">
        <span class="card-date">${fmt(card.createdAt)}</span>
        ${imgCount ? `<span class="card-img-badge">🖼 ${imgCount}</span>` : ""}
      </div>`;
    div.addEventListener("dragstart", e => onDragStart(e, card.id));
    div.addEventListener("dragend",   e => div.classList.remove("dragging"));
    div.addEventListener("click",     () => openModal(card.id));
    return div;
  }

  function makeBacklogCard(card) {
    const div = document.createElement("div");
    div.className = "backlog-card";
    div.innerHTML = `
      <div>
        <div class="backlog-card-title">${esc(card.title)}</div>
        <div class="backlog-card-date">${fmt(card.createdAt)}</div>
      </div>`;
    div.addEventListener("click", () => openModal(card.id));
    return div;
  }

  function esc(s) {
    return (s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
  }

  // ── ADD CARD ─────────────────────────────────────────────────────────────
  function addCard(status) {
    const inp = document.getElementById("inp-"+status);
    const title = inp.value.trim();
    if (!title) return;
    const card = {
      id: uid(), title, status, detail: "", images: [],
      createdAt: Date.now(), order: Date.now()
    };
    window._cards[card.id] = card;
    inp.value = "";
    window.persistCard(card);
  }
  window.addCard = addCard;

  function addCardKey(e, status) {
    if (e.key === "Enter") addCard(status);
  }
  window.addCardKey = addCardKey;

  // ── DRAG & DROP ───────────────────────────────────────────────────────────
  function onDragStart(e, id) {
    dragId = id;
    setTimeout(() => document.querySelector(`[data-id="${id}"]`)?.classList.add("dragging"), 0);
    e.dataTransfer.effectAllowed = "move";
  }

  function onDragOver(e, col) {
    e.preventDefault();
    col.classList.add("drag-over");
    // ghost insertion
    const cards = col.querySelector(".col-cards");
    let ghost = document.querySelector(".card-ghost");
    if (!ghost) { ghost = document.createElement("div"); ghost.className = "card-ghost"; }
    const afterEl = getDragAfterElement(cards, e.clientY);
    if (afterEl) cards.insertBefore(ghost, afterEl);
    else cards.appendChild(ghost);
  }
  window.onDragOver = onDragOver;

  function onDragLeave(e, col) {
    if (!col.contains(e.relatedTarget)) {
      col.classList.remove("drag-over");
      document.querySelector(".card-ghost")?.remove();
    }
  }
  window.onDragLeave = onDragLeave;

  function onDrop(e, col) {
    e.preventDefault();
    col.classList.remove("drag-over");
    document.querySelector(".card-ghost")?.remove();
    if (!dragId) return;
    const newStatus = col.dataset.status;
    const cards = col.querySelector(".col-cards");
    const afterEl = getDragAfterElement(cards, e.clientY);
    // compute order
    const siblings = [...cards.querySelectorAll(".card")].map(d => d.dataset.id);
    const afterIdx = afterEl ? siblings.indexOf(afterEl.dataset.id) : siblings.length;
    const card = window._cards[dragId];
    if (!card) return;
    card.status = newStatus;
    card.order  = Date.now() + afterIdx;
    window.persistCard(card);
    showToast("Movido a " + STATUS_LABEL[newStatus]);
    dragId = null;
  }
  window.onDrop = onDrop;

  function getDragAfterElement(container, y) {
    const els = [...container.querySelectorAll(".card:not(.dragging)")];
    return els.reduce((closest, el) => {
      const box = el.getBoundingClientRect();
      const offset = y - box.top - box.height / 2;
      if (offset < 0 && offset > closest.offset) return { offset, el };
      return closest;
    }, { offset: Number.NEGATIVE_INFINITY }).el;
  }

  // ── MODAL ─────────────────────────────────────────────────────────────────
  function openModal(id) {
    editingId = id;
    const card = window._cards[id];
    if (!card) return;

    document.getElementById("modalTitle").value  = card.title  || "";
    document.getElementById("modalDetail").value = card.detail || "";
    document.getElementById("modalStatus").value = card.status;

    const pill = document.getElementById("modalPill");
    pill.textContent  = STATUS_LABEL[card.status];
    pill.className    = "modal-status-pill " + STATUS_PILL[card.status];

    renderModalImages(card.images || []);
    document.getElementById("modalOverlay").classList.add("open");

    // auto-resize textarea
    const t = document.getElementById("modalTitle");
    t.style.height = "auto"; t.style.height = t.scrollHeight + "px";
    t.addEventListener("input", () => { t.style.height="auto"; t.style.height=t.scrollHeight+"px"; });
  }
  window.openModal = openModal;

  function closeModal() {
    document.getElementById("modalOverlay").classList.remove("open");
    editingId = null;
  }
  window.closeModal = closeModal;

  function closeModalOutside(e) {
    if (e.target === document.getElementById("modalOverlay")) closeModal();
  }
  window.closeModalOutside = closeModalOutside;

  function saveModal() {
    if (!editingId) return;
    const card = window._cards[editingId];
    if (!card) return;
    card.title  = document.getElementById("modalTitle").value.trim() || card.title;
    card.detail = document.getElementById("modalDetail").value;
    const newStatus = document.getElementById("modalStatus").value;
    if (newStatus !== card.status) {
      card.status = newStatus;
      const pill = document.getElementById("modalPill");
      pill.textContent = STATUS_LABEL[newStatus];
      pill.className   = "modal-status-pill " + STATUS_PILL[newStatus];
    }
    window.persistCard(card);
    closeModal();
    showToast("Guardado ✓");
  }
  window.saveModal = saveModal;

  function deleteCard() {
    if (!editingId) return;
    if (!confirm("¿Eliminar esta tarea?")) return;
    window.removeCard(editingId);
    closeModal();
    showToast("Tarea eliminada");
  }
  window.deleteCard = deleteCard;

  // ── IMAGES ───────────────────────────────────────────────────────────────
  function renderModalImages(images) {
    const grid = document.getElementById("imgGrid");
    grid.innerHTML = "";
    images.forEach((src, i) => {
      const wrap = document.createElement("div");
      wrap.className = "img-thumb";
      wrap.innerHTML = `<img src="${src}" alt="img"><button class="img-del" data-idx="${i}">✕</button>`;
      wrap.querySelector("img").addEventListener("click", () => openLightbox(src));
      wrap.querySelector(".img-del").addEventListener("click", e => { e.stopPropagation(); removeImg(i); });
      grid.appendChild(wrap);
    });
    // add button
    const addBtn = document.createElement("div");
    addBtn.className = "img-add-btn";
    addBtn.innerHTML = `<span>+</span><span>Subir</span>`;
    addBtn.addEventListener("click", () => {
      activeImgCardId = editingId;
      document.getElementById("file-input").click();
    });
    grid.appendChild(addBtn);
  }

  function removeImg(idx) {
    const card = window._cards[editingId];
    if (!card) return;
    card.images.splice(idx, 1);
    renderModalImages(card.images);
    window.persistCard(card);
  }

  function handleFileInput(e) {
    const files = [...e.target.files];
    const id = activeImgCardId || editingId;
    if (!id) return;
    files.forEach(f => {
      const reader = new FileReader();
      reader.onload = ev => {
        const card = window._cards[id];
        if (!card) return;
        card.images = card.images || [];
        card.images.push(ev.target.result);
        if (editingId === id) renderModalImages(card.images);
        window.persistCard(card);
      };
      reader.readAsDataURL(f);
    });
    e.target.value = "";
  }
  window.handleFileInput = handleFileInput;

  // Ctrl+V paste
  document.addEventListener("paste", e => {
    if (!editingId) return;
    const items = [...(e.clipboardData?.items || [])];
    items.forEach(item => {
      if (!item.type.startsWith("image/")) return;
      const blob = item.getAsFile();
      const reader = new FileReader();
      reader.onload = ev => {
        const card = window._cards[editingId];
        if (!card) return;
        card.images = card.images || [];
        card.images.push(ev.target.result);
        renderModalImages(card.images);
        window.persistCard(card);
        showToast("Imagen pegada ✓");
      };
      reader.readAsDataURL(blob);
    });
  });

  function openLightbox(src) {
    document.getElementById("lightboxImg").src = src;
    document.getElementById("lightbox").classList.add("open");
  }

  // ── BACKLOG TOGGLE ────────────────────────────────────────────────────────
  function toggleBacklog() {
    const list  = document.getElementById("backlog-list");
    const arrow = document.getElementById("backlogArrow");
    list.classList.toggle("open");
    arrow.classList.toggle("open");
  }
  window.toggleBacklog = toggleBacklog;

  // ── TOAST ─────────────────────────────────────────────────────────────────
  let _toastTimer;
  function showToast(msg) {
    const t = document.getElementById("toast");
    t.textContent = msg; t.classList.add("show");
    clearTimeout(_toastTimer);
    _toastTimer = setTimeout(() => t.classList.remove("show"), 2200);
  }

  // Esc closes modal / lightbox
  document.addEventListener("keydown", e => {
    if (e.key === "Escape") {
      document.getElementById("lightbox").classList.remove("open");
      if (document.getElementById("modalOverlay").classList.contains("open")) closeModal();
    }
  });
</script>
</body>
</html>
