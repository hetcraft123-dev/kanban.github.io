<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#080810">
  <title>Tablero RR Importaciones · Hetcraft</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:         #080810;
      --bg2:        #0e0e1a;
      --bg3:        #141422;
      --bg4:        #1a1a2e;
      --border:     #252540;
      --border2:    #30305a;
      --text:       #dcdcf0;
      --muted:      #6060a0;
      --accent:     #6c63ff;
      --accent2:    #8b85ff;
      --accent-glow:rgba(108,99,255,0.35);
      --todo:       #ff6b9d;
      --todo-glow:  rgba(255,107,157,0.25);
      --prog:       #ffa94d;
      --prog-glow:  rgba(255,169,77,0.25);
      --done:       #51cf66;
      --done-glow:  rgba(81,207,102,0.25);
      --backlog:    #748ffc;
      --backlog-glow:rgba(116,143,252,0.2);
      --radius:     12px;
      --card-r:     10px;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'Syne', sans-serif;
      overflow-x: hidden;
    }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 4px; }

    /* ─── HEADER ─── */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 32px 16px;
      border-bottom: 1px solid var(--border);
      background: linear-gradient(to bottom, rgba(8,8,16,0.98), rgba(8,8,16,0.9));
      position: sticky; top: 0; z-index: 100;
      backdrop-filter: blur(12px);
    }
    .logo {
      display: flex; align-items: center; gap: 10px;
      font-size: 20px; font-weight: 800; letter-spacing: -0.5px;
    }
    .logo-dot {
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 12px var(--accent-glow);
    }
    .header-right {
      display: flex; align-items: center; gap: 12px;
    }
    .sync-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--done);
      box-shadow: 0 0 8px var(--done-glow);
      transition: all 0.3s;
    }
    .sync-dot.syncing { background: var(--prog); box-shadow: 0 0 8px var(--prog-glow); animation: pulse 1s infinite; }
    .sync-dot.offline { background: var(--todo); box-shadow: 0 0 8px var(--todo-glow); }
    @keyframes pulse { 0%,100% { opacity:1 } 50% { opacity:0.4 } }

    /* ─── MAIN LAYOUT ─── */
    main {
      padding: 24px 24px 0;
      display: flex;
      flex-direction: column;
      gap: 24px;
      min-height: calc(100vh - 65px);
    }

    /* ─── BOARD (3 COLUMNS) ─── */
    .board {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      align-items: start;
    }

    /* ─── COLUMN ─── */
    .column {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .column.drag-over {
      border-color: var(--accent);
      box-shadow: 0 0 20px var(--accent-glow);
    }
    .col-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 16px 12px;
      border-bottom: 1px solid var(--border);
    }
    .col-title {
      display: flex; align-items: center; gap: 8px;
      font-size: 13px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase;
    }
    .col-dot {
      width: 8px; height: 8px; border-radius: 50%;
    }
    .col-count {
      font-family: 'DM Mono', monospace;
      font-size: 11px; color: var(--muted);
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 6px; padding: 2px 7px;
    }
    .col-cards {
      padding: 10px;
      min-height: 80px;
      display: flex; flex-direction: column; gap: 7px;
    }
    .col-add {
      padding: 8px 10px 12px;
      display: flex; gap: 6px;
    }
    .col-add input {
      flex: 1;
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 8px; padding: 8px 10px;
      font-family: 'Syne', sans-serif; font-size: 13px;
      color: var(--text); outline: none;
      transition: border-color 0.2s;
    }
    .col-add input:focus { border-color: var(--border2); }
    .col-add input::placeholder { color: var(--muted); }
    .btn-add-card {
      width: 32px; height: 32px;
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 8px; color: var(--muted);
      cursor: pointer; font-size: 18px; line-height: 1;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
    }
    .btn-add-card:hover { color: var(--accent); border-color: var(--accent); background: var(--bg4); }

    /* ─── CARD ─── */
    .card {
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: var(--card-r);
      padding: 11px 13px;
      cursor: grab;
      transition: all 0.18s;
      user-select: none;
      position: relative;
    }
    .card:hover {
      border-color: var(--border2);
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    }
    .card:active { cursor: grabbing; }
    .card.dragging {
      opacity: 0.35;
      transform: scale(0.97);
    }
    .card-title {
      font-size: 13.5px; font-weight: 600; line-height: 1.4;
      color: var(--text);
    }
    .card-meta {
      display: flex; align-items: center; gap: 6px; margin-top: 7px;
    }
    .card-date {
      font-family: 'DM Mono', monospace;
      font-size: 10px; color: var(--muted);
    }
    .card-img-badge {
      font-size: 10px; color: var(--muted);
      display: flex; align-items: center; gap: 3px;
    }

    /* ─── BACKLOG SECTION ─── */
    .backlog-section {
      border-top: 1px solid var(--border);
      margin-top: 8px;
    }
    .backlog-toggle {
      display: flex; align-items: center; gap: 10px;
      padding: 14px 24px;
      cursor: pointer;
      font-size: 13px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; color: var(--backlog);
      background: none; border: none; width: 100%;
      text-align: left;
      transition: color 0.2s;
    }
    .backlog-toggle:hover { color: var(--text); }
    .backlog-arrow { transition: transform 0.25s; font-size: 12px; }
    .backlog-arrow.open { transform: rotate(90deg); }
    .backlog-count {
      font-family: 'DM Mono', monospace;
      font-size: 11px; color: var(--muted);
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 6px; padding: 2px 7px; margin-left: 2px;
    }
    .backlog-list {
      display: none;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 8px;
      padding: 4px 24px 24px;
    }
    .backlog-list.open { display: grid; }
    .backlog-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-left: 3px solid var(--backlog);
      border-radius: var(--card-r);
      padding: 10px 13px;
      cursor: pointer;
      transition: all 0.15s;
      display: flex; align-items: flex-start; justify-content: space-between; gap: 8px;
    }
    .backlog-card:hover { border-color: var(--backlog); transform: translateY(-1px); }
    .backlog-card-title { font-size: 13px; font-weight: 600; color: var(--text); flex: 1; }
    .backlog-card-date {
      font-family: 'DM Mono', monospace;
      font-size: 9px; color: var(--muted); white-space: nowrap; margin-top: 2px;
    }

    /* ─── GHOST CARD (drop placeholder) ─── */
    .card-ghost {
      height: 42px;
      border: 2px dashed var(--accent);
      border-radius: var(--card-r);
      background: var(--accent-glow);
      animation: ghostPulse 1s ease infinite;
    }
    @keyframes ghostPulse { 0%,100%{opacity:.5} 50%{opacity:1} }

    /* ─── MODAL ─── */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 1000;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(6px);
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--bg2);
      border: 1px solid var(--border2);
      border-radius: 16px;
      width: 100%; max-width: 680px;
      max-height: 88vh;
      display: flex; flex-direction: column;
      overflow: hidden;
      transform: scale(0.97) translateY(8px);
      transition: transform 0.25s cubic-bezier(.16,1,.3,1);
      box-shadow: 0 24px 80px rgba(0,0,0,0.6), 0 0 0 1px var(--border);
    }
    .modal-overlay.open .modal { transform: scale(1) translateY(0); }
    .modal-top {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 20px 20px 14px;
      border-bottom: 1px solid var(--border);
    }
    .modal-status-pill {
      font-size: 10px; font-weight: 700; letter-spacing: 1px;
      text-transform: uppercase; border-radius: 6px;
      padding: 3px 8px; margin-top: 3px; white-space: nowrap;
    }
    .modal-title-wrap { flex: 1; }
    .modal-title {
      width: 100%; background: none; border: none;
      font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 700;
      color: var(--text); outline: none; line-height: 1.3;
      resize: none; overflow: hidden;
    }
    .modal-close {
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 8px; color: var(--muted);
      width: 30px; height: 30px; cursor: pointer; font-size: 16px;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.15s; flex-shrink: 0;
    }
    .modal-close:hover { color: var(--text); border-color: var(--border2); }
    .modal-body {
      flex: 1; overflow-y: auto; padding: 18px 20px;
      display: flex; flex-direction: column; gap: 16px;
    }
    .modal-section-label {
      font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--muted); margin-bottom: 6px;
    }
    .modal-detail {
      width: 100%; min-height: 100px;
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 10px; padding: 12px;
      font-family: 'Syne', sans-serif; font-size: 14px; line-height: 1.6;
      color: var(--text); outline: none; resize: vertical;
      transition: border-color 0.2s;
    }
    .modal-detail:focus { border-color: var(--border2); }
    .modal-detail::placeholder { color: var(--muted); }

    /* images */
    .img-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: 8px;
    }
    .img-thumb {
      aspect-ratio: 1; border-radius: 8px;
      overflow: hidden; border: 1px solid var(--border);
      position: relative; cursor: pointer;
      transition: all 0.15s;
    }
    .img-thumb:hover { border-color: var(--border2); transform: scale(1.02); }
    .img-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .img-thumb .img-del {
      position: absolute; top: 4px; right: 4px;
      background: rgba(0,0,0,0.7); border: none; border-radius: 4px;
      color: #fff; font-size: 11px; width: 20px; height: 20px;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.15s;
    }
    .img-thumb:hover .img-del { opacity: 1; }
    .img-add-btn {
      aspect-ratio: 1; border-radius: 8px;
      border: 2px dashed var(--border2); background: var(--bg3);
      cursor: pointer; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 4px;
      color: var(--muted); font-size: 22px;
      transition: all 0.15s;
    }
    .img-add-btn span { font-family: 'Syne', sans-serif; font-size: 10px; }
    .img-add-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--bg4); }
    .paste-hint {
      font-family: 'DM Mono', monospace;
      font-size: 10px; color: var(--muted); margin-top: 4px;
    }
    .paste-hint kbd {
      background: var(--bg4); border: 1px solid var(--border2);
      border-radius: 4px; padding: 1px 5px;
    }

    /* modal footer */
    .modal-footer {
      padding: 12px 20px;
      border-top: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; gap: 10px;
    }
    .modal-status-select {
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 8px; padding: 7px 10px;
      font-family: 'Syne', sans-serif; font-size: 13px; color: var(--text);
      outline: none; cursor: pointer; transition: border-color 0.2s;
    }
    .modal-status-select:focus { border-color: var(--border2); }
    .modal-footer-btns { display: flex; gap: 8px; }
    .btn-danger {
      background: none; border: 1px solid rgba(255,107,107,0.3);
      border-radius: 8px; padding: 7px 14px;
      font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 600;
      color: #ff6b6b; cursor: pointer; transition: all 0.15s;
    }
    .btn-danger:hover { background: rgba(255,107,107,0.1); border-color: #ff6b6b; }
    .btn-save {
      background: var(--accent); border: none;
      border-radius: 8px; padding: 7px 18px;
      font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700;
      color: #fff; cursor: pointer;
      box-shadow: 0 0 16px var(--accent-glow);
      transition: all 0.15s;
    }
    .btn-save:hover { background: var(--accent2); transform: translateY(-1px); }

    /* ─── image lightbox ─── */
    .lightbox {
      position: fixed; inset: 0; z-index: 2000;
      background: rgba(0,0,0,0.92);
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s;
    }
    .lightbox.open { opacity: 1; pointer-events: all; }
    .lightbox img {
      max-width: 100%; max-height: 100%;
      border-radius: 10px; object-fit: contain;
    }

    /* ─── TOAST ─── */
    .toast {
      position: fixed; bottom: 24px; left: 50%;
      transform: translateX(-50%) translateY(12px);
      background: var(--bg3); border: 1px solid var(--border2);
      border-radius: 10px; padding: 10px 18px;
      font-size: 13px; font-weight: 600; color: var(--text);
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
      opacity: 0; pointer-events: none;
      transition: all 0.3s;
      z-index: 3000; white-space: nowrap;
    }
    .toast.show {
      opacity: 1; transform: translateX(-50%) translateY(0);
    }

    /* ─── COLUMN COLORS ─── */
    .col-todo   .col-dot { background: var(--todo);   box-shadow: 0 0 8px var(--todo-glow); }
    .col-todo   .col-title { color: var(--todo); }
    .col-prog   .col-dot { background: var(--prog);   box-shadow: 0 0 8px var(--prog-glow); }
    .col-prog   .col-title { color: var(--prog); }
    .col-done   .col-dot { background: var(--done);   box-shadow: 0 0 8px var(--done-glow); }
    .col-done   .col-title { color: var(--done); }

    /* pill colors */
    .pill-todo   { background: rgba(255,107,157,0.12); color: var(--todo); }
    .pill-prog   { background: rgba(255,169,77,0.12);  color: var(--prog); }
    .pill-done   { background: rgba(81,207,102,0.12);  color: var(--done); }
    .pill-backlog{ background: rgba(116,143,252,0.12); color: var(--backlog); }

    /* input upload hidden */
    #file-input { display: none; }

    /* ─── responsive ─── */
    @media(max-width: 750px) {
      .board { grid-template-columns: 1fr; }
      main { padding: 12px 12px 0; }
      header { padding: 14px 16px; }
    }
  </style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-dot"></div>
    Kanban
  </div>
  <div class="header-right">
    <div class="sync-dot" id="syncDot" title="Firebase sync"></div>
  </div>
</header>

<main>
  <div class="board">
    <!-- POR HACER -->
    <div class="column col-todo" id="col-todo" data-status="todo"
         ondragover="onDragOver(event,this)" ondragleave="onDragLeave(event,this)" ondrop="onDrop(event,this)">
      <div class="col-header">
        <div class="col-title"><div class="col-dot"></div>Por hacer</div>
        <div class="col-count" id="cnt-todo">0</div>
      </div>
      <div class="col-cards" id="cards-todo"></div>
      <div class="col-add">
        <input type="text" placeholder="Nueva tarea…" id="inp-todo" onkeydown="addCardKey(event,'todo')">
        <button class="btn-add-card" onclick="addCard('todo')">+</button>
      </div>
    </div>

    <!-- EN PROGRESO -->
    <div class="column col-prog" id="col-prog" data-status="prog"
         ondragover="onDragOver(event,this)" ondragleave="onDragLeave(event,this)" ondrop="onDrop(event,this)">
      <div class="col-header">
        <div class="col-title"><div class="col-dot"></div>En progreso</div>
        <div class="col-count" id="cnt-prog">0</div>
      </div>
      <div class="col-cards" id="cards-prog"></div>
      <div class="col-add">
        <input type="text" placeholder="Nueva tarea…" id="inp-prog" onkeydown="addCardKey(event,'prog')">
        <button class="btn-add-card" onclick="addCard('prog')">+</button>
      </div>
    </div>

    <!-- REALIZADO -->
    <div class="column col-done" id="col-done" data-status="done"
         ondragover="onDragOver(event,this)" ondragleave="onDragLeave(event,this)" ondrop="onDrop(event,this)">
      <div class="col-header">
        <div class="col-title"><div class="col-dot"></div>Realizado</div>
        <div class="col-count" id="cnt-done">0</div>
      </div>
      <div class="col-cards" id="cards-done"></div>
      <div class="col-add">
        <input type="text" placeholder="Nueva tarea…" id="inp-done" onkeydown="addCardKey(event,'done')">
        <button class="btn-add-card" onclick="addCard('done')">+</button>
      </div>
    </div>
  </div>

  <!-- BACKLOG -->
  <div class="backlog-section">
    <button class="backlog-toggle" onclick="toggleBacklog()">
      <span class="backlog-arrow" id="backlogArrow">▶</span>
      Backlog archivado
      <span class="backlog-count" id="cnt-backlog">0</span>
    </button>
    <div class="backlog-list" id="backlog-list"></div>
  </div>
</main>

<!-- MODAL -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModalOutside(event)">
  <div class="modal" id="modal">
    <div class="modal-top">
      <span class="modal-status-pill" id="modalPill"></span>
      <div class="modal-title-wrap">
        <textarea class="modal-title" id="modalTitle" rows="1" placeholder="Título de la tarea…"></textarea>
      </div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div>
        <div class="modal-section-label">Detalle</div>
        <textarea class="modal-detail" id="modalDetail" placeholder="Descripción, notas, contexto…"></textarea>
      </div>
      <div>
        <div class="modal-section-label">Imágenes</div>
        <div class="img-grid" id="imgGrid"></div>
        <div class="paste-hint">Pega con <kbd>Ctrl+V</kbd> o sube desde tu ordenador</div>
      </div>
    </div>
    <div class="modal-footer">
      <select class="modal-status-select" id="modalStatus">
        <option value="todo">Por hacer</option>
        <option value="prog">En progreso</option>
        <option value="done">Realizado</option>
        <option value="backlog">Archivar en backlog</option>
      </select>
      <div class="modal-footer-btns">
        <button class="btn-danger" onclick="deleteCard()">Eliminar</button>
        <button class="btn-save" onclick="saveModal()">Guardar</button>
      </div>
    </div>
  </div>
</div>

<!-- IMAGE LIGHTBOX -->
<div class="lightbox" id="lightbox" onclick="this.classList.remove('open')">
  <img id="lightboxImg" src="" alt="">
</div>

<!-- HIDDEN FILE INPUT -->
<input type="file" id="file-input" accept="image/*" multiple onchange="handleFileInput(event)">

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- FIREBASE -->
